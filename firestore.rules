rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. AJUDANTES GLOBAIS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    // Verifica se o usuário é administrador
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.toLower() == "fluxointeligente.gestao@gmail.com" ||
        request.auth.token.email.toLower() == "suporte@fluxointeligente.com.br" ||
        request.auth.uid == "mQ2P7DiNapeJx1fIJdKFxtJgFLG2" ||
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin")
      );
    }

    // --- 2. REGRAS DE ACESSO ---

    // Bloqueio padrão
    match /{document=**} {
      allow read, write: if false;
    }

    // Perfis de Usuário
    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(uid);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(uid) && request.resource.data.role == resource.data.role)
      );
    }

    // Configurações do Sistema
    match /system_configs/{configId} {
      // Permitir leitura para usuários logados (ex: planos)
      allow read: if isSignedIn();
      // Permitir escrita apenas para administradores
      allow write: if isAdmin();
    }

    // Coleções Compartilhadas
    match /plans/{planId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /chartOfAccounts/{nodeId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /costCenters/{costCenterId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /paymentMethods/{methodId} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    
    // Dados de Clientes
    match /reports/{reportId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /clientDocuments/{docId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.get('clientId', '') == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Agenda Financeira (usando subcoleções ou caminhos planos)
    match /financialAgenda/{clientId}/{document=**} {
      allow read, write: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (resource.data.get('userId', '') == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.get('userId', '') == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /bankStatements/{statementId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /bankReconciliations/{clientId}/{document=**} {
      allow read, write: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.get('clientId', '') == request.auth.uid || isAdmin());
    }

    match /banks/{bankId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.get('clientId', '') == request.auth.uid || isAdmin());
    }

    match /partners/{partnerId} {
      allow read: if isSignedIn() && (resource.data.get('clientId', '') == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (request.resource.data.get('clientId', '') == request.auth.uid || isAdmin());
    }

    // Suporte
    match /channels/{channelId} {
      allow read: if isSignedIn();
      match /messages/{messageId} {
         allow read: if isSignedIn();
         allow create: if isSignedIn();
      }
    }
  }
}
