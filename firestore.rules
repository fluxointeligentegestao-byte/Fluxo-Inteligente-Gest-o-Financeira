rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Identity lookup from the source of truth or master admin email
      return isSignedIn() && (
        request.auth.token.email == "fluxointeligente.gestao@gmail.com" ||
        request.auth.token.email == "suporte@fluxointeligente.com.br" ||
        (exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.get('role', '') == 'admin')
      );
    }

    // --- Validation Blueprints ---

    function isValidUserProfile(data) {
      let requiredFields = ['uid', 'name', 'email', 'role', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             (data.uid == request.auth.uid || isAdmin()) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'client'] &&
             data.createdAt == request.time &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('status' in data) || (data.status in ['Ativo', 'Pendente', 'Inativo'])) &&
             (!('companyName' in data) || (data.companyName is string && data.companyName.size() <= 100));
    }

    function isValidReport(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'title', 'category', 'status', 'period', 'url', 'createdAt']) &&
             data.clientId is string &&
             data.clientName is string &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.status in ['draft', 'published'] &&
             data.period is string &&
             data.url is string &&
             (!('documents' in data) || (data.documents is list && data.documents.size() <= 10)) &&
             data.createdAt == request.time;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['clientId', 'clientName', 'name', 'url', 'type', 'status', 'createdAt']) &&
             data.clientId == request.auth.uid &&
             data.name is string && data.name.size() <= 255 &&
             data.status in ['pending', 'processed', 'rejected'] &&
             data.createdAt == request.time;
    }

    // --- Match Blocks ---

    // Connection Test
    match /test/connection {
      allow get: if isSignedIn();
    }

    match /userProfiles/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin()) && isValidUserProfile(incoming());
      
      allow update: if (
        isSignedIn() && (
          // Client updating self
          (request.auth.uid == uid && 
           incoming().diff(existing()).affectedKeys().hasOnly(['name', 'companyName', 'fcmTokens', 'phone']) &&
           incoming().name is string && incoming().name.size() <= 100 &&
           incoming().uid == existing().uid &&
           incoming().email == existing().email &&
           incoming().role == existing().role &&
           incoming().createdAt == existing().createdAt) ||
          // Admin updating anyone
          isAdmin()
        )
      );
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow get: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      
      allow create: if isAdmin() && isValidReport(incoming());
      allow update: if isAdmin() && isValidReport(incoming());
      allow delete: if isAdmin();
    }

    match /clientDocuments/{docId} {
      allow get: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidDocument(incoming());
      
      allow update: if (
        (isAdmin()) ||
        (isSignedIn() && existing().clientId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name']) &&
         incoming().name is string && incoming().name.size() <= 255)
      );
      
      allow delete: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }

    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
    }

    match /channels/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
        allow create: if isSignedIn() && (request.auth.uid == uid || isAdmin()) && incoming().senderId == request.auth.uid;
      }
    }

    function isValidFinancialEntry(data) {
      return data.keys().hasAll(['date', 'description', 'type', 'value', 'status', 'clientId', 'month']) &&
             data.date is string &&
             data.description is string && data.description.size() <= 500 &&
             data.type in ['pagar', 'receber'] &&
             data.value is number &&
             data.status in ['Pago', 'Parcial', 'Recebido', 'Vencido', 'Pendente'] &&
             data.clientId is string &&
             data.month is string &&
             (!('category' in data) || (data.category is string)) &&
             (!('observation' in data) || (data.observation is string));
    }

    function isValidPayment(data) {
      return data.keys().hasAll(['clientId', 'month', 'amount', 'status']) &&
             data.clientId is string &&
             data.month is string &&
             data.amount is number &&
             data.status in ['pago', 'pendente'] &&
             (!('clientName' in data) || (data.clientName is string && data.clientName.size() <= 100)) &&
             (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    match /payments/{paymentId} {
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin() && isValidPayment(incoming());
    }

    match /system_configs/{configId} {
      allow read, get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /system_counters/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /transactions/{docId} {
      allow get: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /bankStatements/{statementId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && incoming().clientId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && existing().clientId == request.auth.uid);
    }

    match /bankReconciliations/{clientId} {
      allow read: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin() || (isSignedIn() && clientId == request.auth.uid);
      
      match /{monthYear}/{bankId} {
        allow read: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
        allow write: if isAdmin() || (isSignedIn() && clientId == request.auth.uid);
      }
    }

    match /chartOfAccounts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /costCenters/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /banks/{docId} {
      allow get: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
    match /partners/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /paymentMethods/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /financialAgenda/{clientId} {
      allow read: if isSignedIn() && (request.auth.uid == clientId || isAdmin());
      
      match /entries/{entryId} {
        allow read: if isSignedIn() && (request.auth.uid == clientId || clientId == request.auth.uid || isAdmin());
        allow write: if isAdmin() && isValidFinancialEntry(incoming());
      }
      
      // Recursive fallback
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (request.auth.uid == clientId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
