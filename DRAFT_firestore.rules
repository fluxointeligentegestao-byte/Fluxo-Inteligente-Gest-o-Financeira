rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 1. GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "fluxointeligente.gestao@gmail.com" ||
        request.auth.token.email == "suporte@fluxointeligente.com.br" ||
        request.auth.uid == "mQ2P7DiNapeJx1fIJdKFxtJgFLG2"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- 2. VALIDATION BLUEPRINTS ---
    
    function isValidUserProfile(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'client', 'cliente'] &&
             (data.uid == null || data.uid is string);
    }

    // --- 3. RULE BLOCKS ---

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /userProfiles/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow list: if isAdmin(); 
      allow create: if isSignedIn() && isOwner(uid) && isValidUserProfile(incoming());
      allow update: if isSignedIn() && (isAdmin() || (isOwner(uid) && isValidUserProfile(incoming()) && incoming().role == existing().role));
    }

    // System Configs
    match /system_configs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Documents
    match /clientDocuments/{docId} {
      allow read: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().clientId == request.auth.uid;
      allow update: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Financial Agenda
    match /financialAgenda/{clientId}/entries/{entryId} {
      allow read, write: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
    }

    // Reminders
    match /reminders/{reminderId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
    }

    // Plans
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Payments
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /bankStatements/{statementId} {
      allow read: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /bankReconciliations/{clientId}/{document=**} {
      allow read, write: if isSignedIn() && (clientId == request.auth.uid || isAdmin());
    }
  }
}
